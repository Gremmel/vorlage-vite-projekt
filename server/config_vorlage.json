{
  "express": {
    "port": 3000
  },
  "cors": {
    "origins": [
      "http://localhost:5173"
    ],
    "methods": [
      "GET",
      "POST"
    ]
  },
  "JWT": {
    "secret": "eigener schlüsse"
  },
  "ui": {
    "baseUrl": "https://example.org"
  },
  "security": {
    "passwordResetExpiresMinutes": 60,
    "rateLimit": {
      "login": {
        "windowMs": 900000,
        "max": 10
      },
      "passwordReset": {
        "windowMs": 900000,
        "max": 5
      }
    }
  },
  "smtp": {
    "host": "smtp.example.org",
    "port": 587,
    "secure": false,
    "user": "smtp-user",
    "pass": "smtp-password",
    "from": "no-reply@example.org"
  }
}